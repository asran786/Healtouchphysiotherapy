# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection string (Neon, RDS, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Secret used to sign auth JWTs. Must be a long, random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace-with-a-long-random-secret

# Optional: Fast2SMS API key for sending real OTP text messages.
# If unset, OTPs are only shown on-screen in non-production (see ALLOW_DEMO_OTP).
FAST2SMS_API_KEY=

# Set to "true" only for staging/demo environments where it's OK for the API
# to return the OTP in the response body when SMS isn't configured.
# Must be "false" (or unset) in real production.
ALLOW_DEMO_OTP=false

NODE_ENV=development
